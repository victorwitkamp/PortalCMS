{
    "name": "victorwitkamp/portalcms",
    "description": "A PHP framework/CMS that is currently in development.",
    "license": "",
    "require": {
        "php": "8.0.*",
        "ext-curl": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "ext-pdo": "*",
        "league/csv": "^9.7",
        "league/flysystem": "^2.0",
        "league/plates": "*",
        "phpmailer/phpmailer": "~6.0",
        "sensio/framework-extra-bundle": "*",
        "symfony/console": "*",
        "symfony/flex": "*",
        "symfony/framework-bundle": "*",
        "symfony/monolog-bundle": "*",
        "symfony/requirements-checker": "*",
        "symfony/runtime": "*",
        "symfony/twig-bundle": "*",
        "symfony/yaml": "*",
        "tecnickcom/tcpdf": "6.3.5"
    },
    "require-dev": {
        "roave/security-advisories": "dev-latest",
        "symfony/maker-bundle": "^1.33",
        "symfony/debug-bundle": "*",
        "symfony/dotenv": "*",
        "symfony/web-profiler-bundle": "*",
        "symfony/stopwatch": "*",
        "symfony/var-dumper": "*"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": {
            "*": "dist"
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "extra": {
        "public-dir": "portal/",
        "symfony": {
            "require": "5.3.*"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "requirements-checker": "script"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ]
    },
    "conflict": {
        "symfony/symfony": "*"
    }
}
