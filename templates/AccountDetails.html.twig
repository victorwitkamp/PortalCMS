<h3>LABEL_ACCOUNT_DETAILS</h3>
<table class="table table-striped table-condensed">
    <tr>
        <th>LABEL_USER_ID</th>
        <td>{{ user.user_id }}</td>
    </tr>
    <tr>
        <th>LABEL_USER_NAME</th>
        <td>{{ user.user_name }}</td>
    </tr>
    <tr>
        <th>LABEL_USER_EMAIL</th>
        <td>{{ user.user_email }}</td>
    </tr>
    <tr>
        <th>LABEL_USER_LAST_LOGIN_TIMESTAMP</th>
        <td>{{ user.user_last_login_timestamp }}</td>
    </tr>
    <tr>
        <th>LABEL_USER_LAST_FAILED_LOGIN</th>
        <td>{{ user.user_last_failed_login }}</td>
    </tr>
    <tr>
        <th>LABEL_USER_FBID</th>
        <td><form method="post">
            <input type="submit" name="clearUserFbid" class="btn btn-outline-success user_registered-login" value="LABEL_USER_CLEAR_FBID"/></form>
            <a href="#">LABEL_USER_CONNECT_FB</a></td>
    </tr>
    <tr>
        <th>Rollen</th>
        <td>
            <ul>
            {% for role in roles %}
                <li>{{ role.role_name }} ({{ role.role_id }})</li>
            {% endfor %}
            </ul>
        </td>
    </tr>
</table>
