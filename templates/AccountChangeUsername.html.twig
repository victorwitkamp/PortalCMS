<form method="post">
    <h3>LABEL_CHANGE_USERNAME</h3>
    <div class="form-group row">
        <label for="user_name" class="col-sm-4 col-form-label">LABEL_NEW_USERNAME</label>
        <div class="col-sm-8">
            <input type="text" name="user_name" class="form-control" required/>
        </div>
    </div>
    <input type="hidden" name="{{ csrf_token }}" value=""/>
    <input type="submit" name="changeUsername" value="LABEL_SUBMIT" class="btn btn-primary"/>
</form>
