# Normalize line endings to LF in the repository regardless of a
# contributor's local core.autocrlf setting. Git still checks files out
# using each contributor's own line-ending preference; this only controls
# what's actually stored.
* text=auto eol=lf

*.php text eol=lf
*.js text eol=lf
*.mjs text eol=lf
*.css text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.xml text eol=lf
*.config text eol=lf
*.sql text eol=lf
*.SQL text eol=lf
*.ini text eol=lf
*.htaccess text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf

*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
